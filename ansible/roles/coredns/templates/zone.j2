$ORIGIN {{ domain }}.
$TTL 3600

@   IN SOA  ns.{{ domain }}. admin.{{ domain }}. (
        2024010101  ; Serial
        3600        ; Refresh
        600         ; Retry
        86400       ; Expire
        3600        ; Minimum TTL
    )

    IN NS   ns.{{ domain }}.

ns  IN A    {{ static_ip }}

{% for record in dns_records %}
{{ record.name }}   IN A    {{ record.ip }}
{% endfor %}
